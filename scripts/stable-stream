#!/bin/bash
# ===========================================
# Stable Stream Solutions - CLI Control Script
# ===========================================
# Usage: stable-stream [command]
#
# Commands:
#   start      - Start the service
#   stop       - Stop the service
#   restart    - Restart the service
#   status     - Check service status
#   configure  - Re-run interactive configuration
#   logs       - View service logs
#   update     - Update from GitHub (public)
#   dev-update - Update from private repo (requires SSH key)

SERVICE_NAME="stable-stream.service"
CONFIG_FILE="/etc/stable-stream/config.env"
INSTALL_PATH_FILE="/etc/stable-stream/install_path"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Check for sudo
check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${YELLOW}This command requires sudo privileges. Re-running with sudo...${NC}"
        exec sudo "$0" "$@"
    fi
}

# Run a command as the original user (if sudo was used)
run_as_user() {
    if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
        # Ensure Go and Node paths are available
        USER_HOME=$(eval echo "~$SUDO_USER")
        EXTRA_PATH="/usr/local/go/bin:$USER_HOME/go/bin:$USER_HOME/.nvm/versions/node/$(ls $USER_HOME/.nvm/versions/node/ 2>/dev/null | tail -1)/bin:/usr/local/bin"
        sudo -u "$SUDO_USER" env "PATH=$EXTRA_PATH:$PATH" "$@"
    else
        "$@"
    fi
}

# Get install path
get_install_path() {
    if [ -f "$INSTALL_PATH_FILE" ]; then
        cat "$INSTALL_PATH_FILE"
    else
        echo ""
    fi
}

# Commands
cmd_start() {
    echo -e "${CYAN}Starting Stable Stream Services...${NC}"
    sudo systemctl start obs-wayland "$SERVICE_NAME"
    sleep 2
    cmd_status
}

cmd_stop() {
    echo -e "${CYAN}Stopping Stable Stream Services...${NC}"
    sudo systemctl stop "$SERVICE_NAME" obs-wayland
    echo -e "${GREEN}✓ Services stopped${NC}"
}

cmd_restart() {
    echo -e "${CYAN}Restarting Stable Stream Services...${NC}"
    sudo systemctl stop "$SERVICE_NAME" obs-wayland
    sleep 1
    sudo systemctl start "$SERVICE_NAME"
    echo -e "${YELLOW}Waiting for backend to initialize config...${NC}"
    sleep 2
    sudo systemctl start obs-wayland
    sleep 2
    cmd_status
}

cmd_status() {
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}● Stable Stream is running${NC}"
        systemctl status "$SERVICE_NAME" --no-pager | head -10
    else
        echo -e "${RED}○ Stable Stream is stopped${NC}"
    fi
}

cmd_logs() {
    echo -e "${CYAN}Showing logs (Ctrl+C to exit)...${NC}"
    journalctl -u "$SERVICE_NAME" -f --no-pager
}

cmd_configure() {
    INSTALL_PATH=$(get_install_path)
    if [ -z "$INSTALL_PATH" ]; then
        echo -e "${RED}Error: Install path not found. Please reinstall.${NC}"
        exit 1
    fi
    
    # Stop service during configuration
    echo -e "${CYAN}Stopping service for configuration...${NC}"
    sudo systemctl stop "$SERVICE_NAME" 2>/dev/null || true
    
    # Source the start.sh to get configuration functions
    cd "$INSTALL_PATH"
    
    # Run the configuration portion
    echo ""
    echo "=============================================="
    echo "  STABLE STREAM CONFIGURATION"
    echo "=============================================="
    
    # Load existing config
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    
    # Prompt for username
    read -p "Username [$USERNAME]: " NEW_USERNAME
    USERNAME="${NEW_USERNAME:-$USERNAME}"
    
    # Prompt for password change
    read -p "Change password? (y/n) [n]: " CHANGE_PW
    if [ "$CHANGE_PW" = "y" ] || [ "$CHANGE_PW" = "Y" ]; then
        read -sp "New password: " NEW_PASSWORD
        echo ""
        if [ -n "$NEW_PASSWORD" ]; then
            # Using environment variable for NEW_PASSWORD to avoid shell escaping issues in python call
            export NEW_PASSWORD
            PASSWORD_HASH=$(python3 -c "import bcrypt, os; print(bcrypt.hashpw(os.environ['NEW_PASSWORD'].encode(), bcrypt.gensalt()).decode())")
            unset NEW_PASSWORD
        fi
    fi
    
    # Multistream
    DEFAULT_MS="n"
    [ "$MULTISTREAM_ENABLED" = "y" ] && DEFAULT_MS="y"
    read -p "Enable Multi-Streaming? (y/n) [$DEFAULT_MS]: " MS_INPUT
    MULTISTREAM_ENABLED="${MS_INPUT:-$DEFAULT_MS}"
    
    if [ "$MULTISTREAM_ENABLED" = "y" ]; then
        read -p "Maximum stream destinations (1-5) [${MAX_MULTISTREAMS:-3}]: " MS_MAX
        MAX_MULTISTREAMS="${MS_MAX:-${MAX_MULTISTREAMS:-3}}"
    else
        MAX_MULTISTREAMS=0
    fi
    
    # Ingest lock
    DEFAULT_LOCK="n"
    [ "$INGESTS_LOCKED" = "y" ] && DEFAULT_LOCK="y"
    read -p "Lock ingest creation? (y/n) [$DEFAULT_LOCK]: " LOCK_INPUT
    INGESTS_LOCKED="${LOCK_INPUT:-$DEFAULT_LOCK}"
    
    # Save configuration with SINGLE quotes to prevent bash expansion of $ characters in hashes
    # We explicitly preserve JWT_SECRET and other non-interactive variables
    sudo tee "$CONFIG_FILE" > /dev/null <<EOF
USERNAME='$USERNAME'
PASSWORD_HASH='$PASSWORD_HASH'
MULTISTREAM_ENABLED='$MULTISTREAM_ENABLED'
MAX_MULTISTREAMS='$MAX_MULTISTREAMS'
INGESTS_LOCKED='$INGESTS_LOCKED'
JWT_SECRET='$JWT_SECRET'
JWT_PUBLIC_KEY='$JWT_PUBLIC_KEY'
EOF
    
    # Sync to database
    echo -e "${CYAN}Syncing to database...${NC}"
    if [ -z "$PASSWORD_HASH" ]; then
        echo -e "${RED}Error: PASSWORD_HASH is empty. Configuration may be corrupted.${NC}"
        exit 1
    fi

    export USERNAME PASSWORD_HASH INSTALL_PATH
    SYNC_RESULT=$(python3 -c "
import sqlite3
import os
import sys

try:
    username = os.environ.get('USERNAME')
    password_hash = os.environ.get('PASSWORD_HASH')
    install_path = os.environ.get('INSTALL_PATH')
    
    if not username or not password_hash:
        print('Error: Missing environment variables for sync')
        sys.exit(1)

    db_path = os.path.join(install_path, 'data.db')
    if not os.path.exists(db_path):
        print(f'Error: Database not found at {db_path}')
        sys.exit(1)
        
    conn = sqlite3.connect(db_path)
    c = conn.cursor()
    # Ensure users table exists
    c.execute('CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY, username TEXT UNIQUE, password_hash TEXT NOT NULL)')
    # Update single user record
    c.execute('DELETE FROM users')
    c.execute('INSERT INTO users (username, password_hash) VALUES (?, ?)', (username, password_hash))
    conn.commit()
    conn.close()
    print('SUCCESS')
except Exception as e:
    print(f'Error: {str(e)}')
    sys.exit(1)
" 2>&1)

    if [[ "$SYNC_RESULT" == *"SUCCESS"* ]]; then
        echo -e "${GREEN}✓ Database synced${NC}"
    else
        echo -e "${RED}Failed to sync database:${NC}"
        echo "$SYNC_RESULT"
        echo -e "${YELLOW}Warning: Backend authentication may be out of sync${NC}"
    fi
    
    echo -e "${GREEN}✓ Configuration saved${NC}"
    
    # Restart service
    echo -e "${CYAN}Starting service...${NC}"
    sudo systemctl start "$SERVICE_NAME"
    sleep 1
    cmd_status
}

cmd_update() {
    INSTALL_PATH=$(get_install_path)
    if [ -z "$INSTALL_PATH" ]; then
        echo -e "${RED}Error: Install path not found. Please reinstall.${NC}"
        exit 1
    fi
    
    echo -e "${CYAN}Updating Stable Stream...${NC}"
    echo ""
    
    cd "$INSTALL_PATH"
    
    # Check for updates
    echo "Fetching latest from GitHub..."
    run_as_user git fetch origin main --tags
    
    LOCAL=$(run_as_user git rev-parse HEAD)
    REMOTE=$(run_as_user git rev-parse origin/main)
    
    if [ "$LOCAL" = "$REMOTE" ]; then
        echo -e "${GREEN}✓ Source code is up to date${NC}"
        if [ "$NON_INTERACTIVE" = "true" ]; then
            echo "Non-interactive mode: Rebuilding anyway."
        else
            read -p "Force rebuild anyway? (y/n) [n]: " FORCE_REBUILD
            if [[ ! "$FORCE_REBUILD" =~ ^[Yy] ]]; then
                exit 0
            fi
            echo -e "${CYAN}Forcing rebuild...${NC}"
        fi
    else
        echo "Updates available. Pulling..."
        run_as_user git pull origin main
    fi
    
    # Stop services
    echo ""
    echo "Stopping services..."
    sudo systemctl stop "$SERVICE_NAME" obs-wayland
    
    # Fix permissions and Clean previous builds
    if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
        echo "Ensuring file ownership for $SUDO_USER..."
        sudo chown -R "$SUDO_USER:$SUDO_USER" "$INSTALL_PATH"
    fi
    
    # Explicitly remove dist to avoid EACCES
    echo "Cleaning old build artifacts..."
    [ -d "frontend/dist" ] && sudo rm -rf frontend/dist

    # Rebuild backend
    echo "Building backend..."
    cd backend
    run_as_user go mod tidy || { echo -e "${RED}go mod tidy failed${NC}"; exit 1; }
    run_as_user go build -o ../bin/server main.go || { echo -e "${RED}Backend build failed${NC}"; exit 1; }
    cd ..
    
    # Rebuild frontend
    echo "Building frontend..."
    cd frontend
    run_as_user npm install || { echo -e "${RED}npm install failed${NC}"; exit 1; }
    run_as_user npm run build || { echo -e "${RED}Frontend build failed${NC}"; exit 1; }
    cd ..

    # Self-update the script in /usr/local/bin
    if [ -f "scripts/stable-stream" ]; then
        echo "Updating CLI script..."
        sudo cp scripts/stable-stream /usr/local/bin/stable-stream
        sudo chmod +x /usr/local/bin/stable-stream
    fi
    
    # Sequential Restart (same logic as cmd_restart)
    echo ""
    echo "Starting Stable Stream Services (Sequential)..."
    sudo systemctl start "$SERVICE_NAME"
    echo -e "${YELLOW}Waiting for backend to initialize config...${NC}"
    sleep 2
    sudo systemctl start obs-wayland
    
    sleep 2
    
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo ""
        echo -e "${GREEN}✓ Update complete and service restarted${NC}"
    else
        echo ""
        echo -e "${RED}⚠ Update complete but service may have failed to start${NC}"
        echo "Check logs with: stable-stream logs"
    fi
}

cmd_dev_update() {
    INSTALL_PATH=$(get_install_path)
    if [ -z "$INSTALL_PATH" ]; then
        echo -e "${RED}Error: Install path not found. Please reinstall.${NC}"
        exit 1
    fi
    
    echo -e "${CYAN}Updating Stable Stream from PRIVATE repository...${NC}"
    echo -e "${YELLOW}Note: Requires SSH key or token with access to github.com/OHMEED/stable-stream-solutions${NC}"
    echo ""
    
    cd "$INSTALL_PATH"
    
    # Set remote to private repo (use SSH for auth)
    PRIVATE_REPO="git@github.com:OHMEED/stable-stream-solutions.git"
    
    # Check current remote
    CURRENT_REMOTE=$(run_as_user git remote get-url origin 2>/dev/null)
    if [ "$CURRENT_REMOTE" != "$PRIVATE_REPO" ]; then
        echo "Switching remote to private repository..."
        run_as_user git remote set-url origin "$PRIVATE_REPO"
    fi
    
    # Check for updates
    echo "Fetching latest from private GitHub repo..."
    run_as_user git fetch origin main --tags
    
    LOCAL=$(run_as_user git rev-parse HEAD)
    REMOTE=$(run_as_user git rev-parse origin/main)
    
    if [ "$LOCAL" = "$REMOTE" ]; then
        echo -e "${GREEN}✓ Source code is up to date${NC}"
        if [ "$NON_INTERACTIVE" = "true" ]; then
            echo "Non-interactive mode: Rebuilding anyway."
        else
            read -p "Force rebuild anyway? (y/n) [n]: " FORCE_REBUILD
            if [[ ! "$FORCE_REBUILD" =~ ^[Yy] ]]; then
                exit 0
            fi
            echo -e "${CYAN}Forcing rebuild...${NC}"
        fi
    else
        echo "Updates available. Pulling..."
        run_as_user git pull origin main
    fi
    
    # Stop services
    echo ""
    echo "Stopping services..."
    sudo systemctl stop "$SERVICE_NAME" obs-wayland
    
    # Fix permissions and Clean previous builds
    if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
        echo "Ensuring file ownership for $SUDO_USER..."
        sudo chown -R "$SUDO_USER:$SUDO_USER" "$INSTALL_PATH"
    fi
    
    # Explicitly remove dist to avoid EACCES
    echo "Cleaning old build artifacts..."
    [ -d "frontend/dist" ] && sudo rm -rf frontend/dist

    # Rebuild backend
    echo "Building backend..."
    cd backend
    run_as_user go mod tidy || { echo -e "${RED}go mod tidy failed${NC}"; exit 1; }
    run_as_user go build -o ../bin/server main.go || { echo -e "${RED}Backend build failed${NC}"; exit 1; }
    cd ..
    
    # Rebuild frontend
    echo "Building frontend..."
    cd frontend
    run_as_user npm install || { echo -e "${RED}npm install failed${NC}"; exit 1; }
    run_as_user npm run build || { echo -e "${RED}Frontend build failed${NC}"; exit 1; }
    cd ..

    # Self-update the script in /usr/local/bin
    if [ -f "scripts/stable-stream" ]; then
        echo "Updating CLI script..."
        sudo cp scripts/stable-stream /usr/local/bin/stable-stream
        sudo chmod +x /usr/local/bin/stable-stream
    fi
    
    # Sequential Restart (same logic as cmd_restart)
    echo ""
    echo "Starting Stable Stream Services (Sequential)..."
    sudo systemctl start "$SERVICE_NAME"
    echo -e "${YELLOW}Waiting for backend to initialize config...${NC}"
    sleep 2
    sudo systemctl start obs-wayland
    
    sleep 2
    
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo ""
        echo -e "${GREEN}✓ Dev update complete and service restarted${NC}"
    else
        echo ""
        echo -e "${RED}⚠ Dev update complete but service may have failed to start${NC}"
        echo "Check logs with: stable-stream logs"
    fi
}

cmd_version() {
    INSTALL_PATH=$(get_install_path)
    if [ -f "$INSTALL_PATH/VERSION" ]; then
        VERSION=$(cat "$INSTALL_PATH/VERSION")
        echo -e "${CYAN}Stable Stream CLI v$VERSION${NC}"
    else
        echo -e "${RED}CLI Version unknown (VERSION file missing)${NC}"
    fi

    # Try to get backend version from API (only if running)
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        BACKEND_VERSION=$(curl -s http://localhost:8080/server/api/system/version | python3 -c "import sys, json; print(json.load(sys.stdin).get('current_version', 'unknown'))" 2>/dev/null)
        if [ "$BACKEND_VERSION" != "" ] && [ "$BACKEND_VERSION" != "null" ]; then
            echo -e "${GREEN}Stable Stream Backend v$BACKEND_VERSION${NC}"
        else
            echo -e "${YELLOW}Could not query backend version (API unreachable)${NC}"
        fi
    else
        echo -e "${YELLOW}Backend is stopped - cannot query API version${NC}"
    fi
}

cmd_help() {
    echo "Stable Stream Solutions - CLI Control"
    echo ""
    echo "Usage: stable-stream [command]"
    echo ""
    echo "Commands:"
    echo "  start      - Start the service"
    echo "  stop       - Stop the service"
    echo "  restart    - Restart the service"
    echo "  status     - Check service status"
    echo "  configure  - Re-run interactive configuration"
    echo "  logs       - View service logs"
    echo "  update     - Update from GitHub (public repo)"
    echo "  dev-update - Update from private repo (requires SSH key)"
    echo "  version    - Show version info"
    echo "  help       - Show this help message"
}

# Main
case "${1:-status}" in
    start)
        check_sudo "$@"
        cmd_start
        ;;
    stop)
        check_sudo "$@"
        cmd_stop
        ;;
    restart)
        check_sudo "$@"
        cmd_restart
        ;;
    status)    cmd_status ;;
    configure)
        check_sudo "$@"
        cmd_configure
        ;;
    logs)      cmd_logs ;;
    update)
        shift # move past 'update'
        NON_INTERACTIVE="false"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                -y)                 NON_INTERACTIVE="true" ;;
                --yes)              NON_INTERACTIVE="true" ;;
                --non-interactive)  NON_INTERACTIVE="true" ;;
            esac
            shift
        done
        check_sudo "update"
        cmd_update
        ;;
    version)
        cmd_version
        ;;
    dev-update)
        shift # move past 'dev-update'
        NON_INTERACTIVE="false"
        while [ "$#" -gt 0 ]; do
            case "$1" in
                -y)                 NON_INTERACTIVE="true" ;;
                --yes)              NON_INTERACTIVE="true" ;;
                --non-interactive)  NON_INTERACTIVE="true" ;;
            esac
            shift
        done
        check_sudo "dev-update"
        cmd_dev_update
        ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        cmd_help
        exit 1
        ;;
esac
# End of script

